<view class="page"><view class="table-head"><text class="head-cell">序号</text><text class="head-cell">数量</text><text class="head-cell">重量</text><text class="head-cell">箱号</text><text class="head-cell head-action">操作</text></view><scroll-view scroll-y class="list-wrap"><view wx:for="{{a}}" wx:for-item="item" wx:key="f" class="row" bindtap="{{item.g}}"><text class="cell seq">{{item.a}}</text><text class="cell">{{item.b}}</text><text class="cell">{{item.c}}kg</text><text class="cell">{{item.d}}</text><text class="cell action" catchtap="{{item.e}}">删除</text></view></scroll-view><view class="stats"><text>总箱数: {{b}}</text><text>总数量: {{c}}</text><text>总重量: {{d}}kg</text></view><view class="bottom-actions"><view class="btn primary" bindtap="{{e}}">扫码</view><view class="btn" bindtap="{{f}}">清空</view><view class="btn accent" bindtap="{{g}}">操作</view></view><view wx:if="{{h}}" class="mask" bindtap="{{i}}"></view><view wx:if="{{j}}" class="detail-popup"><view class="title">整箱详情 - {{k}}</view><view class="detail-body"><scroll-view wx:if="{{l}}" scroll-y class="detail-list"><view wx:for="{{m}}" wx:for-item="line" wx:key="c" class="detail-line"><text>{{line.a}}</text><text>{{line.b}}</text></view></scroll-view><view wx:else class="detail-empty">暂无产品</view></view><view class="close-btn" bindtap="{{n}}"> 关闭 </view></view><view wx:if="{{o}}" class="mask" bindtap="{{p}}"></view><view wx:if="{{q}}" class="action-popup"><view class="title">操作</view><view class="action-item" bindtap="{{r}}">导出并出库</view><view class="action-item" bindtap="{{s}}">导出</view><view class="action-item" bindtap="{{t}}">出库</view><view class="action-item" bindtap="{{v}}">入库</view><view class="close-btn secondary" bindtap="{{w}}">取消</view></view><view wx:if="{{x}}" class="mask" bindtap="{{y}}"></view><view wx:if="{{z}}" class="export-popup"><view class="title">导出文件名</view><input class="export-input" placeholder="请输入文件名" confirm-type="done" value="{{A}}" bindinput="{{B}}"/><view class="popup-actions"><view class="popup-btn cancel" bindtap="{{C}}">取消</view><view class="popup-btn confirm" bindtap="{{D}}">确定</view></view></view></view>