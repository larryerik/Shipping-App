.page{min-height:100vh;padding:32rpx;background:linear-gradient(180deg,#eef4ff,#f9fbff)}.header{margin-bottom:28rpx}.header-title{display:block;font-size:46rpx;font-weight:700;color:#1e2a44;margin-bottom:8rpx}.header-subtitle{display:block;font-size:26rpx;color:#5f6b85}.card-list{display:flex;flex-direction:column;gap:20rpx}.menu-card{background:#fff;border-radius:22rpx;padding:28rpx 26rpx;box-shadow:0 8rpx 24rpx rgba(20,50,100,.08)}.menu-title{display:block;font-size:34rpx;font-weight:700;color:#2a4f95;margin-bottom:8rpx}.menu-desc{display:block;font-size:25rpx;color:#6f7c97}.title{font-size:36rpx;color:#8f8f94}
